# Full stack (after `docker compose up -d` + `npm run wait-for-services`):
# E2E_ALL=1

# Optional: per-backend flags (see tests/e2e/helpers/e2eEnv.js)
# E2E_POSTGRES=1
# E2E_MYSQL=1
# E2E_MONGODB=1
# E2E_REDIS=1
# E2E_NEO4J=1
# E2E_ELASTICSEARCH=1
# E2E_CHROMA=1

# PostgreSQL
# PG_HOST=127.0.0.1
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=postgres
# PG_DATABASE=aerekos_record_test
# E2E_POSTGRES_URL=postgres://postgres:postgres@127.0.0.1:5432/aerekos_record_test

# MySQL
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=root
# MYSQL_DATABASE=aerekos_record_test

# MongoDB
# MONGO_URI=mongodb://127.0.0.1:27017
# MONGO_DB=aerekos_record_test

# Redis
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# Neo4j
# NEO4J_URI=bolt://127.0.0.1:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=testpassword

# Elasticsearch
# ES_URL=http://127.0.0.1:9200

# Chroma
# CHROMA_BASE_URL=http://127.0.0.1:8000
# Verbose Chroma HTTP logs (optional)
# AEREKOS_DEBUG_CHROMA=1
