{
  "name": "aerekos-record",
  "version": "0.1.2",
  "description": "Universal ORM for Node.js with Active Record-style syntax across multiple databases",
  "main": "index.js",
  "files": [
    "index.js",
    "chroma",
    "elasticsearch",
    "mongodb",
    "neo4j",
    "psql",
    "redis",
    "sqlite",
    "mysql",
    "shared",
    "utils",
    "aerekos-storage"
  ],
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:coverage": "jest tests/unit tests/e2e --runInBand --coverage",
    "test:coverage:all": "E2E_ALL=1 jest tests/unit tests/e2e --runInBand --coverage",
    "test:unit": "jest tests/unit",
    "test:e2e": "jest tests/e2e --runInBand",
    "test:e2e:ci": "E2E_ALL=1 jest tests/e2e --runInBand",
    "test:e2e:docker": "npm run wait-for-services && npm run test:e2e:ci",
    "wait-for-services": "wait-on -t 180000 tcp:5432 tcp:3306 tcp:6379 tcp:27017 tcp:7687 tcp:9200 tcp:8000"
  },
  "prepublishOnly": "npm run test:coverage",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "orm",
    "active-record",
    "neo4j",
    "mongodb",
    "postgresql",
    "sqlite",
    "elasticsearch",
    "redis",
    "mysql",
    "mariadb",
    "chroma"
  ],
  "license": "MIT",
  "author": "Aerekos",
  "homepage": "https://github.com/dallasrlones/aerekos-record#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dallasrlones/aerekos-record.git"
  },
  "bugs": {
    "url": "https://github.com/dallasrlones/aerekos-record/issues"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3"
  },
  "peerDependencies": {
    "@elastic/elasticsearch": "^8.0.0",
    "better-sqlite3": "^9.0.0 || ^10.0.0 || ^11.0.0",
    "mongodb": "^6.0.0",
    "neo4j-driver": "^5.0.0",
    "pg": "^8.11.0",
    "redis": "^4.6.0",
    "mysql2": "^3.9.0"
  },
  "peerDependenciesMeta": {
    "@elastic/elasticsearch": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    },
    "neo4j-driver": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "redis": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    }
  },
  "devDependencies": {
    "@elastic/elasticsearch": "^8.16.2",
    "better-sqlite3": "^11.8.1",
    "jest": "^29.7.0",
    "mysql2": "^3.12.0",
    "mongodb": "^6.12.0",
    "neo4j-driver": "^5.27.0",
    "pg": "^8.13.1",
    "redis": "^4.7.0",
    "wait-on": "^8.0.1"
  }
}
